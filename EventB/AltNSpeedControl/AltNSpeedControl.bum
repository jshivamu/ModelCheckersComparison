    <org.eventb.core.event name="M" org.eventb.core.convergence="0" org.eventb.core.extended="false" org.eventb.core.label="UpdateThrottleAboveRateLimit">
        <org.eventb.core.guard name="'" org.eventb.core.label="grd1" org.eventb.core.predicate="(new_throttle − engine_throttle) &gt; max_throttle_increase"/>
        <org.eventb.core.action name="(" org.eventb.core.assignment="engine_throttle ≔ engine_throttle + max_throttle_increase" org.eventb.core.label="act1"/>
        <org.eventb.core.guard name=")" org.eventb.core.label="grd2" org.eventb.core.predicate="engine_throttle ≤ max_throttle − max_throttle_increase"/>
