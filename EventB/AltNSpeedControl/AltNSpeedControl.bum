    <org.eventb.core.event name=":" org.eventb.core.convergence="0" org.eventb.core.extended="false" org.eventb.core.label="AltNSpeedControlLoopNormal">
        <org.eventb.core.guard name="'" org.eventb.core.label="grd1" org.eventb.core.predicate="current_mode = normal" org.eventb.core.theorem="true"/>
        <org.eventb.core.guard name="(" org.eventb.core.label="grd2" org.eventb.core.predicate="actual_airspeed ≥ stall_speed"/>
        <org.eventb.core.guard name=")" org.eventb.core.label="grd3" org.eventb.core.predicate="reference_altitude &lt; (actual_altitude + 100)"/>
        <org.eventb.core.action name="*" org.eventb.core.assignment="temp_pitch ≔ (reference_altitude − actual_altitude)÷100" org.eventb.core.label="act1"/>
        <org.eventb.core.action name="+" org.eventb.core.assignment="new_throttle ≔ engine_throttle + (reference_airspeed − actual_airspeed)÷10" org.eventb.core.label="act2"/>
        <org.eventb.core.action name="," org.eventb.core.assignment="time_climb ≔ 0" org.eventb.core.label="act3"/>
        <org.eventb.core.action name="-" org.eventb.core.assignment="time_stall ≔ 0" org.eventb.core.label="act4"/>
