        <org.eventb.core.guard name="'" org.eventb.core.label="grd1" org.eventb.core.predicate="current_mode = normal"/>
        <org.eventb.core.guard name="(" org.eventb.core.label="grd2" org.eventb.core.predicate="actual_airspeed &lt; stall_speed"/>
        <org.eventb.core.action name=")" org.eventb.core.assignment="time_stall ≔ time_stall + 1" org.eventb.core.label="act1"/>
        <org.eventb.core.guard name="*" org.eventb.core.label="grd3" org.eventb.core.predicate="time_stall &lt; 100"/>
        <org.eventb.core.action name="+" org.eventb.core.assignment="temp_pitch ≔ (reference_altitude − actual_altitude)÷1000" org.eventb.core.label="act2"/>
        <org.eventb.core.action name="," org.eventb.core.assignment="new_throttle ≔ engine_throttle + (reference_airspeed − actual_airspeed)÷10" org.eventb.core.label="act3"/>
    </org.eventb.core.event>
    <org.eventb.core.event name="A" org.eventb.core.convergence="0" org.eventb.core.extended="false" org.eventb.core.label="AltNSpeedControlToStallRecovery">
        <org.eventb.core.guard name="'" org.eventb.core.label="grd1" org.eventb.core.predicate="current_mode = normal"/>
        <org.eventb.core.guard name="(" org.eventb.core.label="grd2" org.eventb.core.predicate="time_stall ≥ 100"/>
        <org.eventb.core.guard name=")" org.eventb.core.label="grd3" org.eventb.core.predicate="actual_airspeed &lt; stall_speed"/>
        <org.eventb.core.action name="*" org.eventb.core.assignment="current_mode ≔ stall_recovery" org.eventb.core.label="act1"/>
        <org.eventb.core.action name="+" org.eventb.core.assignment="time_stall_exit ≔ 0" org.eventb.core.label="act2"/>
        <org.eventb.core.action name="," org.eventb.core.assignment="new_throttle ≔ 100" org.eventb.core.label="act3"/>
