        <org.eventb.core.guard name="(" org.eventb.core.label="grd2" org.eventb.core.predicate="actual_airspeed &lt; (stall_speed + 5)"/>
        <org.eventb.core.action name=")" org.eventb.core.assignment="new_throttle ≔ 100" org.eventb.core.label="act1"/>
        <org.eventb.core.action name="*" org.eventb.core.assignment="temp_pitch ≔ (reference_altitude − actual_altitude)÷100" org.eventb.core.label="act2"/>
        <org.eventb.core.action name="+" org.eventb.core.assignment="time_stall_exit ≔ 0" org.eventb.core.label="act3"/>
