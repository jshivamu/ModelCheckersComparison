    <org.eventb.core.invariant name="7" org.eventb.core.label="inv7" org.eventb.core.predicate="current_mode ∈ mode" org.eventb.core.theorem="true"/>
    <org.eventb.core.invariant name="8" org.eventb.core.label="inv8" org.eventb.core.predicate="time_stall ∈ 0‥101"/>
