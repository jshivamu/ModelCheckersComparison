    <org.eventb.core.event name="L" org.eventb.core.convergence="0" org.eventb.core.extended="false" org.eventb.core.label="UpdateThrottleWithinRateLimit">
        <org.eventb.core.guard name="(" org.eventb.core.label="grd2" org.eventb.core.predicate="((new_throttle − engine_throttle) ≤ max_throttle_increase)"/>
        <org.eventb.core.action name=")" org.eventb.core.assignment="engine_throttle ≔ new_throttle" org.eventb.core.label="act1"/>
        <org.eventb.core.guard name="*" org.eventb.core.label="grd3" org.eventb.core.predicate="new_throttle ≤ max_throttle"/>
        <org.eventb.core.guard name="+" org.eventb.core.label="grd4" org.eventb.core.predicate="new_throttle ≥ min_throttle"/>
