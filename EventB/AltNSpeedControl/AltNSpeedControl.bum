    <org.eventb.core.variable name=";" org.eventb.core.identifier="time_climb"/>
    <org.eventb.core.invariant name="=" org.eventb.core.label="inv10" org.eventb.core.predicate="time_climb ∈ 0‥101 "/>
    <org.eventb.core.variable name="&gt;" org.eventb.core.identifier="temp_pitch"/>
