    <org.eventb.core.seesContext name="(" org.eventb.core.target="Ctx"/>
    <org.eventb.core.variable name=")" org.eventb.core.identifier="actual_altitude"/>
    <org.eventb.core.variable name="*" org.eventb.core.identifier="reference_altitude"/>
    <org.eventb.core.variable name="+" org.eventb.core.identifier="actual_airspeed"/>
