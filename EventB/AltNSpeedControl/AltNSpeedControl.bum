    </org.eventb.core.event>
    <org.eventb.core.invariant name="B" org.eventb.core.label="inv11" org.eventb.core.predicate="new_throttle ∈ −10000‥20000 "/>
    <org.eventb.core.invariant name="C" org.eventb.core.label="inv12" org.eventb.core.predicate="temp_pitch ∈ −20‥20"/>
    <org.eventb.core.invariant name="D" org.eventb.core.label="inv13" org.eventb.core.predicate="((current_mode = normal ∧ actual_airspeed &lt; stall_speed ∧ (time_stall ≥ 10)) ⇒ current_mode = stall_recovery)" org.eventb.core.theorem="true"/>
    <org.eventb.core.variable name="E" org.eventb.core.identifier="time_climb_exit"/>
    <org.eventb.core.variable name="F" org.eventb.core.identifier="time_stall_exit"/>
    <org.eventb.core.invariant name="G" org.eventb.core.label="inv14" org.eventb.core.predicate="time_climb_exit ∈ 0‥101 "/>
