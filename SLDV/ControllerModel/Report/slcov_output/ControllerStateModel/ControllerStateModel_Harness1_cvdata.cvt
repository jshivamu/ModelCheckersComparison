  codeblock {
    id			    87
    slsfobj		    19
    code		    "Climb\nentry:\nController_State_Out = Controller.Climb\ncount_stall_recov = 1;\ncount_normal = 1;\nduri"
    "ng:\n%\n% Transition from state Climb to Normal\nif Actual_Alt_In > Ref_Altitude_In\n    if (count_normal >= PERSI"
    "STENCT)\n        Controller_State_Out = Controller.Normal;\n    else\n        count_normal = count_normal + 1;\n  "
    "  end\nelse\n    count_normal = 1;\nend\n%\n% Transition from state Climb to StallRecovery\nif Actual_Speed_In < S"
    "TALL_SPEED\n    if (count_stall_recov >= PERSISTENCT)\n        Controller_State_Out = Controller.StallRecovery;\n "
    "   else\n        count_stall_recov = count_stall_recov + 1;\n    end\nelse\n    count_stall_recov = 1;\nend\n%\n% "
    "Computation\nPitch_Cmd_Out = CLIMB_PITCH_CMD;\nEngn_Throttle_Out = 100.0;\nexit:"
    totalNumOfObjs	    [4 0 0 0]
  }
