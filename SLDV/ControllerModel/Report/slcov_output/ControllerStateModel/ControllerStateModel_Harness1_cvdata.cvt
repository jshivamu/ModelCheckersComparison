  codeblock {
    id			    123
    slsfobj		    20
    code		    "Normal\nentry:\nController_State_Out = Controller.Normal;\ncount_stall_recov = 1;\ncount_climb = 1;\ndu"
    "ring:\n%\n% Transition from state Normal to Climb\nif ((Ref_Altitude_In - Actual_Alt_In) >= ALT_THRESHOLD)\n    if"
    " (count_climb >= PERSISTENCT)\n        Controller_State_Out = Controller.Climb;\n    else\n        count_climb = c"
    "ount_climb + 1;\n    end\nelse\n    count_climb = 1;\nend\n%\n% Transition from state Normal to StallRecovery\nif "
    "Actual_Speed_In < STALL_SPEED\n    if (count_stall_recov >= PERSISTENCT)\n        Controller_State_Out = Controlle"
    "r.StallRecovery;\n    else\n        count_stall_recov = count_stall_recov + 1;\n    end\nelse\n    count_stall_rec"
    "ov = 1;\nend\n%\n% Computation\nPitch_Cmd_Out = (Ref_Altitude_In - Actual_Alt_In) * GAIN;\nEngn_Throttle_Out = (Re"
    "f_Speed_In - Actual_Speed_In) * GAIN;\nexit:\n"
    totalNumOfObjs	    [4 0 0 0]
  }
